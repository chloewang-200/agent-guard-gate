# Production / preview: full URL to the deployed Custos Next app (custos_app).
# Example: https://custos-demo.vercel.app
# Used for marketing-site → POST {VITE_CUSTOS_APP_URL}/api/waitlist (CORS enabled on that route).
# Local dev on http://localhost:5173 (Vite marketing): set this and run Custos on 8080.
# One command for both: `yarn dev:all` (see root package.json). Or two terminals: `yarn dev` + `yarn dev:custos`.
VITE_CUSTOS_APP_URL=http://localhost:8080

# Optional: proxy POST /api/waitlist from Vite dev server to an external URL (e.g. Form endpoint).
# If unset and VITE_CUSTOS_APP_URL is unset, Vite answers POST /api/waitlist with { ok: true } in dev only.
WAITLIST_ENDPOINT=
