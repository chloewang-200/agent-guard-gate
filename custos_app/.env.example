# ================================================================================
# APPLICATION & API
# ================================================================================
NODE_ENV=development
NEXT_PUBLIC_API_URL=
VERCEL_URL=

# ================================================================================
# NEXTAUTH & AUTHENTICATION
# ================================================================================
# URL must match the site origin (magic links include this host).
# Local: http://localhost:8080 · Production: https://your-domain.com
# Vercel previews: leave unset to auto-use https://$VERCEL_URL (see src/lib/auth.ts)
NEXTAUTH_URL=http://localhost:8080
NEXTAUTH_SECRET=
# Toggle auth enforcement (false = bypass for local development)
NEXT_PUBLIC_ENABLE_AUTH=false

# DynamoDB adapter for NextAuth sessions (optional; defaults to in-memory)
AWS_REGION=us-east-1
NEXTAUTH_DYNAMODB_TABLE=next-auth
# AWS credentials for DynamoDB (optional; uses IAM role if not set)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ================================================================================
# EMAIL (for magic links)
# ================================================================================
# SMTP server configuration for sending magic links
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=

# ================================================================================
# INVOICE EXTRACTION (OpenAI, Claude, or Custom Microservice)
# ================================================================================
# Pipeline order: microservice → Anthropic/Claude → OpenAI (images) → fallback message
# Files stored under .invoice-uploads/ on the Next server (nodejs runtime).

# Optional: Invoice extraction microservice (POST /extract endpoint)
# CUSTOS_INVOICE_AGENT_URL=http://127.0.0.1:4001/extract
CUSTOS_INVOICE_AGENT_URL=

# Anthropic Claude (supports PDF + images)
# Get key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Alternative alias (same key as ANTHROPIC_API_KEY)
# CLAUDE_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI Vision (images only; PDF requires Anthropic or microservice)
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o-mini

# ================================================================================
# FILE STORAGE (Supabase for Invoice Uploads)
# ================================================================================
# Optional; enables invoice file storage on Vercel when both are set
# Get credentials from: https://supabase.com/
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# Private bucket name (create in Dashboard → Storage → New bucket, disable public access)
# SUPABASE_INVOICE_BUCKET=invoice-uploads

# ================================================================================
# STRIPE (Payments & Top-ups)
# ================================================================================
# Get test/live keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret: stripe listen --forward-to localhost:8080/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=
# DynamoDB table for Stripe top-up idempotency (create via scripts/create-custos-dynamo-tables.sh)
CUSTOS_STRIPE_CREDITS_TABLE=custos-stripe-credits

# ================================================================================
# FEATURE FLAGS
# ================================================================================
# Invoice agent (defaults ON in next dev; set explicitly for production)
# CUSTOS_ENABLE_INVOICE_FEATURES=true
# NEXT_PUBLIC_CUSTOS_ENABLE_INVOICE_FEATURES=true

# Experimental features (e.g., API keys, advanced policies)
# CUSTOS_ENABLE_EXPERIMENTAL_FEATURES=true
# NEXT_PUBLIC_CUSTOS_ENABLE_EXPERIMENTAL_FEATURES=true

# Agent API key management
# CUSTOS_ENABLE_AGENT_API_KEYS=true
# NEXT_PUBLIC_CUSTOS_ENABLE_AGENT_API_KEYS=true

# API rate limiting (when Upstash Redis is configured)
# CUSTOS_ENABLE_API_RATE_LIMIT=true

# ================================================================================
# DYNAMODB TABLES (Demo/Core Data)
# ================================================================================
# AWS_REGION must be set above for these to work
CUSTOS_USERS_TABLE=custos-users
CUSTOS_WORKSPACES_TABLE=custos-workspaces
CUSTOS_WALLETS_TABLE=custos-wallets
CUSTOS_AGENTS_TABLE=custos-agents
CUSTOS_TRANSACTIONS_TABLE=custos-transactions
CUSTOS_VENDORS_TABLE=custos-vendors

# Default workspace for demo mode (optional)
# CUSTOS_DEFAULT_WORKSPACE_ID=

# ================================================================================
# REDIS (Optional; for rate limiting & caching)
# ================================================================================
# Upstash Redis REST API (when using Redis-backed rate limiting)
# Get credentials from: https://console.upstash.com/
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# ================================================================================
# OBSERVABILITY (Sentry Error Tracking)
# ================================================================================
# Get DSN from: https://sentry.io/
# SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/yyyy
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
