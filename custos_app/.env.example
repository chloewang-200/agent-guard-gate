# Next.js
NEXT_PUBLIC_API_URL=
# Optional: full URL to waitlist if not on this app’s home (defaults to /#beta).
# NEXT_PUBLIC_WAITLIST_URL=https://custos.example/#beta

# Waitlist: POST /api/waitlist saves only if BOTH are set on this Next.js deployment (not optional “one of two”):
#   • WAITLIST_ENDPOINT (external form URL), or
#   • SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY together (use service_role key from Supabase → Settings → API; anon key will not insert).
# If neither pair is configured, the API still returns 200 but nothing is written (UI will say sign-up did not reach the DB).
# GET /api/waitlist (exports rows) requires admin cookie after signing in at https://<your-domain>/admin (Waitlist Admin UI on the Custos Next app).
# Preferred env names — or legacy ADMIN_USER / ADMIN_PASS (same values).
# CUSTOS_WAITLIST_ADMIN_USER=
# CUSTOS_WAITLIST_ADMIN_PASSWORD=
# Signing cookie: CUSTOS_WAITLIST_ADMIN_SECRET (optional) or ADMIN_SESSION_SECRET or NEXTAUTH_SECRET
# CUSTOS_WAITLIST_ADMIN_SECRET=
# ADMIN_USER=
# ADMIN_PASS=
# ADMIN_SESSION_SECRET=
# WAITLIST_ENDPOINT=
# SUPABASE_WAITLIST_TABLE=waitlist

# Supabase (same project as waitlist; enables invoice file storage on Vercel when both are set)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# Private bucket for invoice uploads — create in Dashboard → Storage → New bucket (disable public access).
# SUPABASE_INVOICE_BUCKET=invoice-uploads

# Invoice Agent (upload/extract) — defaults ON in `next dev`. For production builds set:
# NEXT_PUBLIC_CUSTOS_ENABLE_INVOICE_FEATURES=true
# CUSTOS_ENABLE_INVOICE_FEATURES=true
# To hide in development: CUSTOS_ENABLE_INVOICE_FEATURES=false

# Invoice extraction (same order as empire custos_be): microservice URL, then Claude, then OpenAI (images).
# Files are stored under .invoice-uploads/ on the Next server (nodejs runtime).
# CUSTOS_INVOICE_AGENT_URL=http://127.0.0.1:4001/extract
CUSTOS_INVOICE_AGENT_URL=
ANTHROPIC_API_KEY=
# or CLAUDE_API_KEY — optional models:
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o-mini

# NextAuth — URL must match the site origin (magic links include this host).
# Local: http://localhost:8080  ·  Production: https://your-domain.com
# Vercel previews: leave unset to auto-use https://$VERCEL_URL (see src/lib/auth.ts), or set explicitly per preview.
NEXTAUTH_URL=http://localhost:8080
# Required in production for JWT / email verification tokens
NEXTAUTH_SECRET=

EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=

AWS_REGION=us-east-1
NEXTAUTH_DYNAMODB_TABLE=next-auth
CUSTOS_USERS_TABLE=custos-users
CUSTOS_WORKSPACES_TABLE=custos-workspaces
CUSTOS_WALLETS_TABLE=custos-wallets
CUSTOS_AGENTS_TABLE=custos-agents
CUSTOS_TRANSACTIONS_TABLE=custos-transactions
CUSTOS_VENDORS_TABLE=custos-vendors
# PaymentIntent idempotency for Stripe top-ups (create table via custos_app/scripts/create-custos-dynamo-tables.sh)
CUSTOS_STRIPE_CREDITS_TABLE=custos-stripe-credits

# Stripe — wallet top-up (use test keys from https://dashboard.stripe.com/test/apikeys )
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# signing secret: stripe listen --forward-to localhost:8080/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Auth toggle
# When \"true\", NextAuth is enforced for dashboard routes.
# When unset/false, auth is bypassed so you can explore the product UI without a backend.
NEXT_PUBLIC_ENABLE_AUTH=false
