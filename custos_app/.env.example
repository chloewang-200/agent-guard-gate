# Next.js
NEXT_PUBLIC_API_URL=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=

AWS_REGION=us-east-1
NEXTAUTH_DYNAMODB_TABLE=next-auth
CUSTOS_USERS_TABLE=custos-users
CUSTOS_WORKSPACES_TABLE=custos-workspaces
CUSTOS_WALLETS_TABLE=custos-wallets
CUSTOS_AGENTS_TABLE=custos-agents
CUSTOS_TRANSACTIONS_TABLE=custos-transactions
CUSTOS_VENDORS_TABLE=custos-vendors
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Auth toggle
# When \"true\", NextAuth is enforced for dashboard routes.
# When unset/false, auth is bypassed so you can explore the product UI without a backend.
NEXT_PUBLIC_ENABLE_AUTH=false
